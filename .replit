modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "dev-jwt-secret-change-in-production-7qz35cu679u"
VITE_API_URL = "/api"
PRIVATE_KEY = "0x7655cff0b6e766fc4c8a028ee89e1bd4d1d97d66383af12b011e27f4693af669"
SEPOLIA_RPC_URL = "https://ethereum-sepolia-rpc.publicnode.com"
LAND_REGISTRY_ADDRESS = "0x7F5c027Ff6747d6a127861Df9108F5ee2f392da3"
OWNERSHIP_ADDRESS = "0x002f17B92Cb30Bc7e324A4F82e226e5b99c55C72"
VERIFICATION_ADDRESS = "0x1123194a6785E78a5d3Dc2FA8772214172a846D6"
PORT = "3001"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter api dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter web dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "PORT=5000 node apps/api/dist/index.js"]
build = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm --filter api exec prisma generate && pnpm --filter api exec prisma migrate deploy && pnpm --filter web build && pnpm --filter api build"]
