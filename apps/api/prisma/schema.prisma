generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  role          String        @default("landowner")
  password      String
  walletAddress String?       @unique
  createdAt     DateTime      @default(now())
  ownerships    Ownership[]
  boughtTx      Transaction[] @relation("Buyer")
  soldTx        Transaction[] @relation("Seller")
}

model LandParcel {
  id                Int                @id @default(autoincrement())
  titleNumber       String             @unique
  location          String
  size              Float
  status            String             @default("pending")
  createdAt         DateTime           @default(now())
  blockchainRecords BlockchainRecord[]
  documents         Document[]
  ownerships        Ownership[]
  transactions      Transaction[]
}

model Ownership {
  id            Int        @id @default(autoincrement())
  userId        Int
  landId        Int
  ownershipDate DateTime   @default(now())
  land          LandParcel @relation(fields: [landId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
}

model Transaction {
  id               Int                @id @default(autoincrement())
  landId           Int
  sellerId         Int
  buyerId          Int
  transactionDate  DateTime           @default(now())
  status           String             @default("pending")
  blockchainRecord BlockchainRecord[]
  buyer            User               @relation("Buyer", fields: [buyerId], references: [id])
  seller           User               @relation("Seller", fields: [sellerId], references: [id])
  land             LandParcel         @relation(fields: [landId], references: [id])
}

model Document {
  id           Int        @id @default(autoincrement())
  landId       Int
  fileHash     String
  documentType String
  land         LandParcel @relation(fields: [landId], references: [id])
}

model BlockchainRecord {
  id            Int          @id @default(autoincrement())
  landId        Int
  transactionId Int?
  blockHash     String
  timestamp     DateTime     @default(now())
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  land          LandParcel   @relation(fields: [landId], references: [id])
}
